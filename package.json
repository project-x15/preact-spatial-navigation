{
  "name": "@project-x15/preact-spatial-navigation",
  "version": "0.1.0",
  "packageManager": "pnpm@9.5.0",
  "private": true,
  "type": "module",
  "main": "./dist/spatial.umd.js",
  "module": "./dist/spatial.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/spatial.js",
      "require": "./dist/spatial.umd.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/spatial.js",
      "require": "./dist/spatial.umd.js"
    },
    "./preact": {
      "types": "./dist/preact.d.ts",
      "import": "./dist/spatial.js",
      "require": "./dist/spatial.umd.js"
    }
  },
  "scripts": {
    "build": "rollup -c && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "release": "npm run build && git tag v$npm_package_version"
  },
  "dependencies": {
    "@noriginmedia/norigin-spatial-navigation-core": "^4.0.0"
  },
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "jsdom": "^29.1.1",
    "rollup": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "sideEffects": false
}